<div id="cookie-consent" aria-live="polite" role="dialog" aria-label="Cookie consent" class="cookie-consent">
    <div class="cookie-consent-container">
        <div class="cookie-consent-message">
            We use cookies to improve your experience. By choosing Accept you consent to the use of
            non-essential cookies.
        </div>
        <div class="cookie-consent-buttons">
            <button id="cookie-accept" type="button" class="btn btn-primary">Accept</button>
            <button id="cookie-reject" type="button" class="btn btn-outline-secondary">Reject</button>
        </div>
    </div>
</div>